<td>string</td>
<td></td>
</tr>
<tr>
<td>model</td>
<td>型号</td>
<td>string</td>
<td></td>
</tr>
<tr>
<td>firmware</td>
<td>固件版本</td>
<td>string</td>
<td></td>
</tr>
<tr>
