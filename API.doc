<tbody>
<tr>
<td>code</td>
<td>错误码，0为成功</td>
<td>integer(int32)</td>
<td>integer(int32)</td>
</tr>
<tr>
<td>msg</td>
<td>描述，错误时描述错误原因</td>
<td>string</td>
<td></td>
</tr>
<tr>
<td>data</td>
<td>数据</td>
<td>string</td>
<td></td>
</tr>
</tbody>
