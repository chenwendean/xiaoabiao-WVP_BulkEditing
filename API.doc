<h3>2.10.2保存代理(已存在会覆盖)</h3>
<div class="knife4j-word-api">
<div class="knife4j-word-title">接口地址</div>
<div class="knife4j-word-content"><span class="knife4j-word-method">POST</span>&nbsp;&nbsp;<code>/api/proxy/save</code></div>
<div class="knife4j-word-title">接口描述</div>
<div class="knife4j-word-content"></div>
<div class="knife4j-word-title">请求数据类型</div>
<div class="knife4j-word-content"><code>application/x-www-form-urlencoded,application/json</code></div>
<div class="knife4j-word-title">响应数据类型</div>
<div class="knife4j-word-content"><code>*/*</code></div>
<div class="knife4j-word-title">请求示例</div>
<div class="knife4j-word-content">
<pre class="knife4j-word-code-editor">
{
  <span class="key">"type":</span> <span class="string">""</span>,
  <span class="key">"app":</span> <span class="string">""</span>,
  <span class="key">"name":</span> <span class="string">""</span>,
  <span class="key">"stream":</span> <span class="string">""</span>,
  <span class="key">"mediaServerId":</span> <span class="string">""</span>,
  <span class="key">"url":</span> <span class="string">""</span>,
  <span class="key">"timeoutMs":</span> <span class="number">0</span>,
  <span class="key">"ffmpegCmdKey":</span> <span class="string">""</span>,
  <span class="key">"rtpType":</span> <span class="string">""</span>,
  <span class="key">"enable":</span> <span class="boolean">true</span>,
  <span class="key">"enableAudio":</span> <span class="boolean">true</span>,
  <span class="key">"enableMp4":</span> <span class="boolean">true</span>,
  <span class="key">"enableRemoveNoneReader":</span> <span class="boolean">true</span>,
  <span class="key">"enableDisableNoneReader":</span> <span class="boolean">true</span>
}
</pre>
</div>


