<thead><tr><th>参数名称</th><th>参数说明</th><th>请求类型</th><th>必须</th><th>数据类型</th><th>schema</th></tr></thead>
<tbody>
<tr>
<td>app</td>
<td>应用名</td>
<td>query</td>
<td>true</td>
<td>string</td>
<td></td>
</tr>
<tr>
<td>stream</td>
<td>流Id</td>
<td>query</td>
<td>true</td>
<td>string</td>
<td></td>
</tr>
</tbody>
</table>
</div>


