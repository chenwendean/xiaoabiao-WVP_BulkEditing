  <span class="key">"characterSet":</span> <span class="string">""</span>,
  <span class="key">"ptz":</span> <span class="boolean">true</span>,
  <span class="key">"rtcp":</span> <span class="boolean">true</span>,
  <span class="key">"status":</span> <span class="boolean">true</span>,
  <span class="key">"channelCount":</span> <span class="number">0</span>,
  <span class="key">"catalogSubscribe":</span> <span class="boolean">true</span>,
  <span class="key">"alarmSubscribe":</span> <span class="boolean">true</span>,
  <span class="key">"mobilePositionSubscribe":</span> <span class="boolean">true</span>,
  <span class="key">"catalogGroup":</span> <span class="number">0</span>,
  <span class="key">"updateTime":</span> <span class="string">""</span>,
  <span class="key">"createTime":</span> <span class="string">""</span>,
