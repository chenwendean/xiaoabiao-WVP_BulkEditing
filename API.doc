<h3>2.10.7分页查询流代理</h3>
<div class="knife4j-word-api">
<div class="knife4j-word-title">接口地址</div>
<div class="knife4j-word-content"><span class="knife4j-word-method">GET</span>&nbsp;&nbsp;<code>/api/proxy/list</code></div>
<div class="knife4j-word-title">接口描述</div>
<div class="knife4j-word-content"></div>
<div class="knife4j-word-title">请求数据类型</div>
<div class="knife4j-word-content"><code>application/x-www-form-urlencoded</code></div>
<div class="knife4j-word-title">响应数据类型</div>
<div class="knife4j-word-content"><code>*/*</code></div>


<div class="knife4j-word-title">请求参数</div><br/>
<div class="knife4j-word-content">
<table class="knife4j-word-table">
<thead><tr><th>参数名称</th><th>参数说明</th><th>请求类型</th><th>必须</th><th>数据类型</th><th>schema</th></tr></thead>
<tbody>
<tr>
<td>page</td>
<td>当前页</td>
<td>query</td>
<td>false</td>
<td>integer(int32)</td>
<td></td>
</tr>
<tr>
<td>count</td>
<td>每页查询数量</td>
<td>query</td>
<td>false</td>
<td>integer(int32)</td>
<td></td>
</tr>
<tr>
<td>query</td>
<td>查询内容</td>
<td>query</td>
<td>false</td>
<td>string</td>
<td></td>
</tr>
<tr>
<td>pulling</td>
<td>是否正在拉流</td>
<td>query</td>
<td>false</td>
<td>boolean</td>
<td></td>
</tr>
<tr>
<td>mediaServerId</td>
<td>流媒体ID</td>
<td>query</td>
<td>false</td>
<td>string</td>
<td></td>
</tr>
</tbody>
</table>
</div>


