<td>string</td>
<td></td>
</tr>
<tr>
<td>password</td>
<td>密码</td>
<td>string</td>
<td></td>
</tr>
<tr>
<td>sdpIp</td>
<td>收流IP</td>
<td>string</td>
<td></td>
</tr>
<tr>
<td>localIp</td>
<td>SIP交互IP（设备访问平台的IP）</td>
<td>string</td>
<td></td>
</tr>
<tr>
<td>asMessageChannel</td>
<td>是否作为消息通道</td>
<td>boolean</td>
<td></td>
</tr>
<tr>
<td>sipTransactionInfo</td>
<td></td>
