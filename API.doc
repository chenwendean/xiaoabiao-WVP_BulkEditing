<td>false</td>
<td>boolean</td>
<td></td>
</tr>
<tr>
<td>mediaServerId</td>
<td>流媒体ID</td>
<td>query</td>
<td>false</td>
<td>string</td>
<td></td>
</tr>
</tbody>
</table>
