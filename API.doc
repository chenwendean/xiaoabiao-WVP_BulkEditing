<td></td>
</tr>
<tr>
<td>&nbsp;customErrCode</td>
<td>国标-无效原因码(有证书且证书无效的设备必选)</td>
<td>integer(int32)</td>
<td></td>
</tr>
<tr>
<td>&nbsp;customEndTime</td>
<td>国标-证书终止有效期(有证书且证书无效的设备必选)</td>
<td>integer(int32)</td>
<td></td>
</tr>
<tr>
<td>&nbsp;customSecurityLevelCode</td>
<td>国标-摄像机安全能力等级代码</td>
<td>string</td>
<td></td>
</tr>
<tr>
<td>&nbsp;customSecrecy</td>
<td>国标-保密属性(必选)缺省为0;0-不涉密,1-涉密</td>
<td>integer(int32)</td>
<td></td>
</tr>
<tr>
<td>&nbsp;customIpAddress</td>
<td>国标-设备/系统IPv4/IPv6地址</td>
<td>string</td>
<td></td>
</tr>
